# Copy to .env for local development.
# In production these are set on the platform (Railway), never committed.

SECRET_KEY=django-insecure-dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave empty for local SQLite. Railway injects a Postgres URL automatically.
DATABASE_URL=

# Comma-separated frontend origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# AI provider: "mock" (offline, deterministic) or "gemini" (live).
AI_PROVIDER=mock
GEMINI_API_KEY=
